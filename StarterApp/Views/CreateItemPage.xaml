<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.CreateItemPage"
             Title="List an Item">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="Title"/>
            <Entry Text="{Binding Title}" Placeholder="Enter title"/>
            <Label Text="Description"/>
            <Editor Text="{Binding Description}" Placeholder="Describe your item" HeightRequest="100"/>
            <Label Text="Daily Rate (£)"/>
            <Entry Text="{Binding DailyRate}" Keyboard="Numeric"/>
            <Label Text="Category"/>
            <Entry Text="{Binding Category}" Placeholder="e.g. Tools, Games"/>
            <Label Text="Location"/>
            <Entry Text="{Binding Location}" Placeholder="Your area"/>
            <Button Text="List Item" Command="{Binding CreateItemCommand}" Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
