<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.NearbyItemsPage"
             Title="Nearby Items">
    <Grid RowDefinitions="Auto,Auto,*">
        <Label Grid.Row="0" Text="{Binding RadiusKm, StringFormat='Search radius: {0}km'}" Margin="10"/>
        <Button Grid.Row="1" Text="Find Nearby Items" Command="{Binding SearchNearbyCommand}" Margin="10"/>
        <CollectionView Grid.Row="2" ItemsSource="{Binding NearbyItems}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10,5" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" FontAttributes="Bold"/>
                            <Label Text="{Binding DailyRate, StringFormat='£{0}/day'}"/>
                            <Label Text="{Binding Location}" TextColor="Gray"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
